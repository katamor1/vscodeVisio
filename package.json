{
  "name": "vscode-visio",
  "displayName": "VS Code Visio フローチャート",
  "description": "選択した C コードまたは現在の C ファイルから Visio 基本フローチャートの VSDX ファイルを生成します。",
  "version": "0.0.1",
  "publisher": "local",
  "private": true,
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/katamor1/vscodeVisio.git"
  },
  "os": [
    "win32"
  ],
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:c",
    "onCommand:vscodeVisio.generateFlowchartFromSelection"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscodeVisio.generateFlowchartFromSelection",
        "title": "Visio: 選択範囲からフローチャートを生成"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "vscodeVisio.generateFlowchartFromSelection",
          "when": "editorLangId == c",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "VS Code Visio フローチャート",
      "properties": {
        "vscodeVisio.outputDirectory": {
          "type": "string",
          "default": "visio-output",
          "description": "生成した VSDX ファイルの出力先ディレクトリ。相対パスはワークスペースフォルダーから解決されます。"
        },
        "vscodeVisio.visioStencilPath": {
          "type": "string",
          "default": "C:\\\\Program Files\\\\Microsoft Office\\\\Root\\\\Office16\\\\Visio Content\\\\1041\\\\BASFLO_M.VSSX",
          "description": "Visio 基本フローチャートステンシルのパス。"
        },
        "vscodeVisio.openAfterGenerate": {
          "type": "boolean",
          "default": false,
          "description": "生成後に VSDX ファイルを開きます。"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test \"out/test/**/*.test.js\"",
    "verify:visio": "npm run compile && powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/Verify-VisioFlowchart.ps1"
  },
  "dependencies": {
    "tree-sitter-c": "0.24.1",
    "web-tree-sitter": "0.26.9"
  },
  "devDependencies": {
    "@types/node": "22.15.29",
    "@types/vscode": "1.120.0",
    "typescript": "5.8.3"
  }
}
